#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local input="$1"
  if [ -d "$input" ]; then
    cd "$input" && pwd
    return
  fi
  case "$input" in
    /*) printf '%s\n' "$input" ;;
    *) printf '%s/%s\n' "$(pwd)" "$input" ;;
  esac
}

resolve_package_base() {
  if [ -n "${TRIM_APPDEST:-}" ]; then
    resolve_path "$TRIM_APPDEST"
    return
  fi
  cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

PACKAGE_BASE="$(resolve_package_base)"
APP_DIR="$(resolve_path "${DOCKER_MANAGER_APP_DIR:-${TRIM_APPDEST:-$PACKAGE_BASE}}")"
VAR_DIR="$(resolve_path "${DOCKER_MANAGER_VAR_DIR:-${TRIM_PKGVAR:-$PACKAGE_BASE/var}}")"
RUN_DIR="$VAR_DIR/run"
LOG_DIR="$VAR_DIR/logs"

export DOCKER_MANAGER_LOG_FILE="${DOCKER_MANAGER_LOG_FILE:-$LOG_DIR/service.log}"
export DOCKER_MANAGER_PID_FILE="${DOCKER_MANAGER_PID_FILE:-$RUN_DIR/app.pid}"
export DOCKER_MANAGER_SOCKET_FILE="${DOCKER_MANAGER_SOCKET_FILE:-$APP_DIR/app.sock}"
export FNOS_SOCKET_PATH="$DOCKER_MANAGER_SOCKET_FILE"
export FNOS_GATEWAY_PREFIX="${FNOS_GATEWAY_PREFIX:-/app/dockermanager}"
export FNOS_DATA_DIR="$VAR_DIR"
export FNOS_WEB_DIR="${FNOS_WEB_DIR:-$APP_DIR/www}"
export TRIM_APPDEST="$APP_DIR"
export TRIM_PKGVAR="$VAR_DIR"

ensure_runtime_dirs() {
  mkdir -p "$RUN_DIR" "$LOG_DIR"
}

ensure_runtime_dirs

export NODE_ENV=production

CMD="$APP_DIR/server/docker-manager"

log_msg() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$DOCKER_MANAGER_LOG_FILE"
}

check_process() {
  local pid="$1"
  kill -0 "$pid" 2>/dev/null
}

status_process() {
  if [ -f "$DOCKER_MANAGER_PID_FILE" ]; then
    local pid
    pid="$(head -n 1 "$DOCKER_MANAGER_PID_FILE" | tr -d '[:space:]')"
    if [ -n "$pid" ] && check_process "$pid"; then
      return 0
    fi
    rm -f "$DOCKER_MANAGER_PID_FILE"
  fi
  return 3
}

start_process() {
  if status_process; then
    return 0
  fi
  ensure_runtime_dirs
  rm -f "$DOCKER_MANAGER_SOCKET_FILE"
  log_msg "Starting Docker Manager"
  bash -c "$CMD" >> "$DOCKER_MANAGER_LOG_FILE" 2>&1 &
  printf '%s\n' "$!" > "$DOCKER_MANAGER_PID_FILE"
}

stop_process() {
  log_msg "Stopping Docker Manager"
  if [ -f "$DOCKER_MANAGER_PID_FILE" ]; then
    local pid
    pid="$(head -n 1 "$DOCKER_MANAGER_PID_FILE" | tr -d '[:space:]')"
    if [ -n "$pid" ] && check_process "$pid"; then
      kill -TERM "$pid" >> "$DOCKER_MANAGER_LOG_FILE" 2>&1 || true
      local count=0
      while check_process "$pid" && [ "$count" -lt 10 ]; do
        sleep 1
        count=$((count + 1))
      done
      if check_process "$pid"; then
        kill -KILL "$pid" >> "$DOCKER_MANAGER_LOG_FILE" 2>&1 || true
      fi
    fi
    rm -f "$DOCKER_MANAGER_PID_FILE"
  fi
  rm -f "$DOCKER_MANAGER_SOCKET_FILE"
}

case "${1:-}" in
  start) start_process ;;
  stop) stop_process ;;
  status) status_process ;;
  *) exit 1 ;;
esac
