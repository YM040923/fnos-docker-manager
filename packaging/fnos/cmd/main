#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local input="$1"
  if [ -d "$input" ]; then
    cd "$input" && pwd
    return
  fi
  case "$input" in
    /*) printf '%s\n' "$input" ;;
    *) printf '%s/%s\n' "$(pwd)" "$input" ;;
  esac
}

resolve_package_base() {
  if [ -n "${TRIM_APPDEST:-}" ]; then
    resolve_path "$TRIM_APPDEST"
    return
  fi
  cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

PACKAGE_BASE="$(resolve_package_base)"
APP_DIR="$(resolve_path "${DOCKER_MANAGER_APP_DIR:-${TRIM_APPDEST:-$PACKAGE_BASE}}")"
VAR_DIR="$(resolve_path "${DOCKER_MANAGER_VAR_DIR:-${TRIM_PKGVAR:-$PACKAGE_BASE/var}}")"
SCRIPT_PATH="$(resolve_path "${BASH_SOURCE[0]}")"
RUN_DIR="$VAR_DIR/run"
LOG_DIR="$VAR_DIR/logs"
SERVICE_NAME="dockerstart.service"
SERVICE_FILE="/etc/systemd/system/$SERVICE_NAME"

export DOCKER_MANAGER_LOG_FILE="${DOCKER_MANAGER_LOG_FILE:-$LOG_DIR/service.log}"
export DOCKER_MANAGER_PID_FILE="${DOCKER_MANAGER_PID_FILE:-$RUN_DIR/app.pid}"
export DOCKER_MANAGER_SOCKET_FILE="${DOCKER_MANAGER_SOCKET_FILE:-$APP_DIR/app.sock}"
export FNOS_SOCKET_PATH="$DOCKER_MANAGER_SOCKET_FILE"
export FNOS_GATEWAY_PREFIX="${FNOS_GATEWAY_PREFIX:-/app/dockerstart}"
export FNOS_DATA_DIR="$VAR_DIR"
export FNOS_WEB_DIR="${FNOS_WEB_DIR:-$APP_DIR/www}"
export TRIM_APPDEST="$APP_DIR"
export TRIM_PKGVAR="$VAR_DIR"

ensure_runtime_dirs() {
  mkdir -p "$RUN_DIR" "$LOG_DIR"
}

ensure_runtime_dirs

"$(dirname "${BASH_SOURCE[0]}")/icon_sync" >/dev/null 2>&1 || true

export NODE_ENV=production

CMD="$APP_DIR/server/docker-manager"

log_msg() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$DOCKER_MANAGER_LOG_FILE"
}

fail_visible() {
  local message="$1"
  log_msg "$message"
  if [ -n "${TRIM_TEMP_LOGFILE:-}" ]; then
    printf '%s\n' "$message" > "$TRIM_TEMP_LOGFILE" 2>/dev/null || true
  fi
  return 1
}

systemd_available() {
  command -v systemctl >/dev/null 2>&1 && [ -d /etc/systemd/system ]
}

check_process() {
  local pid="$1"
  kill -0 "$pid" 2>/dev/null
}

status_process() {
  if [ -f "$DOCKER_MANAGER_PID_FILE" ]; then
    local pid
    pid="$(head -n 1 "$DOCKER_MANAGER_PID_FILE" | tr -d '[:space:]')"
    if [ -n "$pid" ] && check_process "$pid"; then
      return 0
    fi
    rm -f "$DOCKER_MANAGER_PID_FILE"
  fi
  return 3
}

start_process() {
  if status_process; then
    return 0
  fi
  ensure_runtime_dirs
  rm -f "$DOCKER_MANAGER_SOCKET_FILE"
  log_msg "Starting Docker Manager"
  bash -c "$CMD" >> "$DOCKER_MANAGER_LOG_FILE" 2>&1 &
  printf '%s\n' "$!" > "$DOCKER_MANAGER_PID_FILE"
}

stop_process() {
  log_msg "Stopping Docker Manager"
  if [ -f "$DOCKER_MANAGER_PID_FILE" ]; then
    local pid
    pid="$(head -n 1 "$DOCKER_MANAGER_PID_FILE" | tr -d '[:space:]')"
    if [ -n "$pid" ] && check_process "$pid"; then
      kill -TERM "$pid" >> "$DOCKER_MANAGER_LOG_FILE" 2>&1 || true
      local count=0
      while check_process "$pid" && [ "$count" -lt 10 ]; do
        sleep 1
        count=$((count + 1))
      done
      if check_process "$pid"; then
        kill -KILL "$pid" >> "$DOCKER_MANAGER_LOG_FILE" 2>&1 || true
      fi
    fi
    rm -f "$DOCKER_MANAGER_PID_FILE"
  fi
  rm -f "$DOCKER_MANAGER_SOCKET_FILE"
}

install_autostart() {
  if ! systemd_available; then
    fail_visible "Docker Manager cannot register boot autostart: systemctl is unavailable"
    return 1
  fi

  if ! cat > "$SERVICE_FILE" <<SERVICE
[Unit]
Description=Docker Manager fnOS background service
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=forking
Environment="DOCKER_MANAGER_APP_DIR=$APP_DIR"
Environment="DOCKER_MANAGER_VAR_DIR=$VAR_DIR"
ExecStart=$SCRIPT_PATH start
ExecStop=$SCRIPT_PATH stop
PIDFile=$DOCKER_MANAGER_PID_FILE
Restart=no
TimeoutStartSec=60
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
SERVICE
  then
    fail_visible "Docker Manager cannot write boot autostart service: $SERVICE_FILE"
    return 1
  fi

  chmod 0644 "$SERVICE_FILE" || {
    fail_visible "Docker Manager cannot set boot service permissions: $SERVICE_FILE"
    return 1
  }
  systemctl daemon-reload || {
    fail_visible "Docker Manager cannot reload systemd after boot service registration"
    return 1
  }
  systemctl enable "$SERVICE_NAME" || {
    fail_visible "Docker Manager cannot enable boot autostart service: $SERVICE_NAME"
    return 1
  }
  log_msg "Registered boot autostart service $SERVICE_NAME"
}

remove_autostart() {
  if ! systemd_available; then
    return 0
  fi

  systemctl disable "$SERVICE_NAME" >/dev/null 2>&1 || true
  rm -f "$SERVICE_FILE"
  systemctl daemon-reload || true
  log_msg "Removed boot autostart service $SERVICE_NAME"
}

case "${1:-}" in
  start) start_process ;;
  stop) stop_process ;;
  status) status_process ;;
  install-autostart) install_autostart ;;
  remove-autostart) remove_autostart ;;
  *) exit 1 ;;
esac
